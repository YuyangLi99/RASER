# API keys / secrets
.env
.hf_token
*.key

# Local data and trace files (must be regenerated; large)
# Note: data/holdouts/ IS tracked (holdout QID lists, ~40KB).
# Note: checkpoints/*.pkl ARE tracked (deployment-trained routers, ~21 MB).
# Only the heavy preprocessed corpora under data/processed/ and raw .pkl
# elsewhere are ignored.
data/processed/
data/raw/
data/indexes/
outputs/
catboost_info/
*.jsonl
*.pdf
# Ignore .pkl by default, but allow tracked checkpoints
*.pkl
!checkpoints/**/*.pkl

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp

# Mac
.DS_Store
